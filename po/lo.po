#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:580
msgid "Static binding to skip backward in current track."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອຂ້າມກັບຄືນໃນເພງປັດຈຸບັນ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:585
msgid "Static binding to skip forward in current track."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອຂ້າມໄປຂ້າງໜ້າໃນເພງປັດຈຸບັນ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:590
msgid "Static binding to toggle repeat mode in media player."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອສະຫຼັບໂໝດການຫຼິ້ນຊ້ຳໃນໂປຣແກຣມຫຼິ້ນສື່."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:595
msgid "Static binding to toggle random playback mode in media player."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອສະຫຼັບໂໝດການຫຼິ້ນແບບສຸ່ມໃນໂປຣແກຣມຫຼິ້ນສື່."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:601
msgid "Static binding to toggle automatic screen orientation."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອສະຫຼັບການວາງແນວໜ້າຈໍອັດຕະໂນມັດ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:606
msgid "Static binding for power button."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ສຳລັບປຸ່ມເປີດປິດ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:611
msgid "Static binding to hibernate the machine."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອ hibernate ເຄື່ອງ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:616
msgid "Static binding to suspend the machine."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອ suspend ເຄື່ອງ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:622
msgid "Static binding to increase the keyboard brightness."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອເພີ່ມຄວາມສະຫວ່າງຂອງແປ້ນພິມ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:627
msgid "Static binding to decrease the keyboard brightness."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອຫຼຸດຄວາມສະຫວ່າງຂອງແປ້ນພິມ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:632
msgid "Static binding to toggle the keyboard brightness."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອສະຫຼັບຄວາມສະຫວ່າງຂອງແປ້ນພິມ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:638
msgid "Static binding to show current battery status."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອສະແດງສະຖານະແບັດເຕີຣີປັດຈຸບັນ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:644
msgid "Static binding to toggle airplane mode."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອສະຫຼັບໂໝດເຮືອບິນ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:649
msgid "Static binding to toggle bluetooth airplane mode."
msgstr "ການຈັບຄູ່ແບບຄົງທີ່ເພື່ອສະຫຼັບໂໝດເຮືອບິນຂອງ Bluetooth."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:656
msgid "Name"
msgstr "ຊື່"

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:657
msgid "Name of the custom binding"
msgstr "ຊື່ຂອງການຈັບຄູ່ທີ່ກຳນົດເອງ"

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:661
msgid "Binding"
msgstr "ການຈັບຄູ່"

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:662
msgid "Binding for the custom binding"
msgstr "ການຈັບຄູ່ສຳລັບການຈັບຄູ່ທີ່ກຳນົດເອງ"

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:666
msgid "Command"
msgstr "ຄຳສັ່ງ"

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:667
msgid "Command to run when the binding is invoked"
msgstr "ຄຳສັ່ງທີ່ຈະເຮັດວຽກເມື່ອການຈັບຄູ່ຖືກເອີ້ນໃຊ້"

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:671
msgid "Enable in Lockscreen"
msgstr "ເປີດໃຊ້ໃນໜ້າຈໍລັອກ"

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:672
msgid "Whether the command can be invoked while the lockscreen is shown"
msgstr "ບໍ່ວ່າຄຳສັ່ງຈະສາມາດຖືກເອີ້ນໃຊ້ໄດ້ໃນຂະນະທີ່ໜ້າຈໍລັອກກຳລັງສະແດງຢູ່"

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:6
msgid "The brightness of the screen when idle"
msgstr "ຄວາມສະຫວ່າງຂອງໜ້າຈໍເມື່ອບໍ່ມີການໃຊ້ງານ"

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:7
msgid ""
"This is the laptop panel screen brightness used when the session is idle."
msgstr "ນີ້ແມ່ນຄວາມສະຫວ່າງຂອງໜ້າຈໍແລັບທັອບທີ່ໃຊ້ເມື່ອບໍ່ມີການໃຊ້ງານ."

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:11
msgid "Dim the screen after a period of inactivity"
msgstr "ຫຼຸດຄວາມສະຫວ່າງໜ້າຈໍຫຼັງຈາກບໍ່ມີການໃຊ້ງານໄລຍະໜຶ່ງ"

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:12
msgid "If the screen should be dimmed to save power when the computer is idle."
msgstr "ບໍ່ວ່າໜ້າຈໍຄວນຈະຫຼຸດຄວາມສະຫວ່າງລົງເພື່ອປະຢັດພະລັງງານເມື່ອຄອມພິວເຕີບໍ່ມີການໃຊ້ງານ."

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:16
msgid "Sleep timeout computer when on AC"
msgstr "ເວລາໝົດກຳນົດເພື່ອເຂົ້າໂໝດ sleep ເມື່ອໃຊ້ໄຟ AC"

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:17
msgid ""
"The amount of time in seconds the computer on AC power needs to be inactive "
"before it goes to sleep. A value of 0 means never."
msgstr "ໄລຍະເວລາເປັນວິນາທີທີ່ຄອມພິວເຕີທີ່ໃຊ້ໄຟ AC ຕ້ອງບໍ່ມີການໃຊ້ງານກ່ອນທີ່ຈະເຂົ້າສູ່ໂໝດ sleep. ຄ່າ 0 ໝາຍຄວາມວ່າບໍ່ເຄີຍ."

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:21
#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:31
msgid "Whether to hibernate, suspend or do nothing when inactive"
msgstr "ບໍ່ວ່າຈະ hibernate, suspend ຫຼື ບໍ່ເຮັດຫຍັງເລີຍເມື່ອບໍ່ມີການໃຊ້ງານ"

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:22
#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:32
msgid ""
"The type of sleeping that should be performed when the computer is inactive."
msgstr "ປະເພດຂອງການນອນຫຼັບທີ່ຄວນຈະຖືກປະຕິບັດເມື່ອຄອມພິວເຕີບໍ່ມີການໃຊ້ງານ."

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:26
msgid "Sleep timeout computer when on battery"
msgstr "ເວລາໝົດກຳນົດເພື່ອເຂົ້າໂໝດ sleep ເມື່ອໃຊ້ແບັດເຕີຣີ"

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:27
msgid ""
"The amount of time in seconds the computer on battery power needs to be "
"inactive before it goes to sleep. A value of 0 means never."
msgstr "ໄລຍະເວລາເປັນວິນາທີທີ່ຄອມພິວເຕີທີ່ໃຊ້ແບັດເຕີຣີຕ້ອງບໍ່ມີການໃຊ້ງານກ່ອນທີ່ຈະເຂົ້າສູ່ໂໝດ sleep. ຄ່າ 0 ໝາຍຄວາມວ່າບໍ່ເຄີຍ."

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:36
msgid "Enable the ALS sensor"
msgstr "ເປີດໃຊ້ເຊັນເຊີ ALS"

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:37
msgid "If the ambient light sensor functionality is enabled."
msgstr "ຖ້າຄຸນສົມບັດຂອງເຊັນເຊີແສງສະພາບແວດລ້ອມຖືກເປີດໃຊ້."

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:41
msgid "Power button action"
msgstr "ການກະທຳຂອງປຸ່ມເປີດປິດ"

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:42
msgid ""
"The action to take when the system power button is pressed. Virtual machines "
"only honor the 'nothing' action, and will shutdown otherwise. Tablets always "
"suspend, ignoring all the other action options."
msgstr "ການກະທຳທີ່ຈະເຮັດເມື່ອກົດປຸ່ມເປີດປິດຂອງລະບົບ. ເຄື່ອງຈັກສະເໝືອນຈິງຈະຍອມຮັບພຽງແຕ່ການກະທຳ 'nothing', ແລະຈະປິດເຄື່ອງໃນກໍລະນີອື່ນ. ແທັບເລັດຈະ suspend ສະເໝີ, ໂດຍບໍ່ສົນໃຈຕົວເລືອກການກະທຳອື່ນໆ."

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:46
msgid "Enable power-saver profile when battery is low"
msgstr "ເປີດໂປຣໄຟລ໌ປະຢັດພະລັງງານເມື່ອແບັດເຕີຣີເຫຼືອໜ້ອຍ"

#: data/org.gnome.settings-daemon.plugins.power.gschema.xml.in:47
msgid ""
"Automatically enable the \"power-saver\" profile using power-profiles-daemon "
"if the battery is low."
msgstr "ເປີດໃຊ້ໂປຣໄຟລ໌ \"power-saver\" ໂດຍອັດຕະໂນມັດໂດຍໃຊ້ power-profiles-daemon ຖ້າແບັດເຕີຣີເຫຼືອໜ້ອຍ."

#: data/org.gnome.settings-daemon.plugins.sharing.gschema.xml.in:6
msgid "On which connections the service is enabled"
msgstr "ບໍລິການຖືກເປີດໃຊ້ໃນການເຊື່ອມຕໍ່ໃດແດ່"

#: data/org.gnome.settings-daemon.plugins.sharing.gschema.xml.in:7
msgid ""
"The list of NetworkManager connections (each one represented with its UUID) "
"on which this service is enabled and started."
msgstr "ລາຍຊື່ການເຊື່ອມຕໍ່ NetworkManager (ແຕ່ລະອັນສະແດງດ້ວຍ UUID ຂອງມັນ) ທີ່ບໍລິການນີ້ຖືກເປີດໃຊ້ ແລະ ເລີ່ມຕົ້ນ."

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:6
msgid "List of explicitly disabled GTK+ modules"
msgstr "ລາຍຊື່ໂມດູນ GTK+ ທີ່ຖືກປິດໃຊ້ງານຢ່າງຊັດເຈນ"

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:7
msgid ""
"A list of strings representing the GTK+ modules that will not be loaded, "
"even if enabled by default in their configuration."
msgstr "ລາຍຊື່ຂໍ້ຄວາມທີ່ສະແດງເຖິງໂມດູນ GTK+ ທີ່ຈະບໍ່ຖືກໂຫຼດ, ເຖິງແມ່ນວ່າຈະຖືກເປີດໃຊ້ໂດຍຄ່າເລີ່ມຕົ້ນໃນການຕັ້ງຄ່າຂອງພວກມັນ."

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:11
msgid "List of explicitly enabled GTK+ modules"
msgstr "ລາຍຊື່ໂມດູນ GTK+ ທີ່ຖືກເປີດໃຊ້ງານຢ່າງຊັດເຈນ"

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:12
msgid ""
"A list of strings representing the GTK+ modules that will be loaded, usually "
"in addition to conditional and forcibly disabled ones."
msgstr "ລາຍຊື່ຂໍ້ຄວາມທີ່ສະແດງເຖິງໂມດູນ GTK+ ທີ່ຈະຖືກໂຫຼດ, ໂດຍປົກກະຕິແລ້ວຈະເພີ່ມເຕີມຈາກອັນທີ່ມີເງື່ອນໄຂ ແລະ ອັນທີ່ຖືກປິດໃຊ້ງານໂດຍບັງຄັບ."

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:16
msgid "A dictionary of XSETTINGS to override"
msgstr "ວັດຈະນານຸກົມຂອງ XSETTINGS ເພື່ອລົບລ້າງ"

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:17
msgid ""
"This dictionary maps XSETTINGS names to overrides values. The values must be "
"either strings, signed int32s or (in the case of colors), 4-tuples of uint16 "
"(red, green, blue, alpha; 65535 is fully opaque)."
msgstr "ວັດຈະນານຸກົມນີ້ຈັບຄູ່ຊື່ XSETTINGS ກັບຄ່າລົບລ້າງ. ຄ່າຕ້ອງເປັນຂໍ້ຄວາມ, int32s ມີເຄື່ອງໝາຍ ຫຼື (ໃນກໍລະນີສີ), 4-tuples ຂອງ uint16 (ແດງ, ຂຽວ, ຟ້າ, alpha; 65535 ແມ່ນທຶບແສງເຕັມທີ່)."

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:23
msgid "Antialiasing"
msgstr "ການລົບຂອບ"

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:24
msgid ""
"The type of antialiasing to use when rendering fonts. Possible values are: "
"“none” for no antialiasing, “grayscale” for standard grayscale antialiasing, "
"and “rgba” for subpixel antialiasing (LCD screens only)."
msgstr "ປະເພດຂອງການລົບຂອບທີ່ຈະໃຊ້ເມື່ອສະແດງຟອນ. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ: “none” ສຳລັບບໍ່ມີການລົບຂອບ, “grayscale” ສຳລັບການລົບຂອບແບບສີເທົາທຳມະດາ, ແລະ “rgba” ສຳລັບການລົບຂອບແບບ subpixel (ສຳລັບຈໍ LCD ເທົ່ານັ້ນ)."

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:28
msgid "Hinting"
msgstr "ການໃຫ້ຄຳແນະນຳ"

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:29
msgid ""
"The type of hinting to use when rendering fonts. Possible values are: “none” "
"for no hinting and “slight” for fitting only to the Y-axis like Microsoft’s "
"ClearType, DirectWrite and Adobe’s proprietary font rendering engine. "
"Ignores native hinting within the font, generates hints algorithmically. "
"Used on Ubuntu by default. Recommended. The meaning of “medium” and “full” "
"depends on the font format (.ttf, .otf, .pfa/.pfb) and the installed version "
"of FreeType. They usually try to fit glyphs to both the X and the Y axis "
"(except for .otf: Y-only). This can lead to distortion and/or inconsistent "
"rendering depending on the quality of the font, the font format and the "
"state of FreeType’s font engines."
msgstr "ປະເພດຂອງ hinting ທີ່ຈະໃຊ້ເມື່ອສະແດງຟອນ. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ: “none” ສຳລັບບໍ່ມີ hinting ແລະ “slight” ສຳລັບການປັບໃຫ້ພໍດີກັບແກນ Y ເທົ່ານັ້ນ ຄືກັບ ClearType ຂອງ Microsoft, DirectWrite ແລະ engine ການສະແດງຟອນຂອງ Adobe. ບໍ່ສົນໃຈ hinting ພື້ນເມືອງໃນຟອນ, ສ້າງ hints ດ້ວຍສູດຄິດໄລ່. ໃຊ້ໃນ Ubuntu ເປັນຄ່າເລີ່ມຕົ້ນ. ແນະນຳ. ຄວາມໝາຍຂອງ “medium” ແລະ “full” ຂຶ້ນກັບຮູບແບບຟອນ (.ttf, .otf, .pfa/.pfb) ແລະ ເວີຊັນຂອງ FreeType ທີ່ຕິດຕັ້ງ. ໂດຍປົກກະຕິພວກມັນຈະພະຍາຍາມປັບ glyphs ໃຫ້ພໍດີທັງແກນ X ແລະ Y (ຍົກເວັ້ນ .otf: ສະເພາະ Y). ອັນນີ້ສາມາດນຳໄປສູ່ການບິດເບືອນ ແລະ/ຫຼື ການສະແດງຜົນທີ່ບໍ່ສອດຄ່ອງກັນ ຂຶ້ນກັບຄຸນນະພາບຂອງຟອນ, ຮູບແບບຟອນ ແລະ ສະຖານະຂອງ engine ຟອນຂອງ FreeType."

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:33
msgid "RGBA order"
msgstr "ລຳດັບ RGBA"

#: data/org.gnome.settings-daemon.plugins.xsettings.gschema.xml.in:34
msgid ""
"The order of subpixel elements on an LCD screen; only used when antialiasing "
"is set to “rgba”. Possible values are: “rgb” for red on left (most common), "
"“bgr” for blue on left, “vrgb” for red on top, “vbgr” for red on bottom."
msgstr "ລຳດັບຂອງອົງປະກອບ subpixel ເທິງຈໍ LCD; ໃຊ້ເມື່ອການລົບຂອບຖືກຕັ້ງເປັນ “rgba” ເທົ່ານັ້ນ. ຄ່າທີ່ເປັນໄປໄດ້ແມ່ນ: “rgb” ສຳລັບສີແດງຢູ່ຊ້າຍ (ທົ່ວໄປທີ່ສຸດ), “bgr” ສຳລັບສີຟ້າຢູ່ຊ້າຍ, “vrgb” ສຳລັບສີແດງຢູ່ເທິງ, “vbgr” ສຳລັບສີແດງຢູ່ລຸ່ມ."

