#: data/org.gnome.settings-daemon.global-shortcuts.gschema.xml.in:6
msgid "Applications"
msgstr "ແອັບພລິເຄຊັນ"

#: data/org.gnome.settings-daemon.global-shortcuts.gschema.xml.in:7
msgid "Applications that have defined global shortcuts"
msgstr "ແອັບພລິເຄຊັນທີ່ມີການກຳນົດປຸ່ມລັດແບບທົ່ວໄປ"

#: data/org.gnome.settings-daemon.global-shortcuts.gschema.xml.in:13
msgid "Shortcuts"
msgstr "ປຸ່ມລັດ"

#: data/org.gnome.settings-daemon.global-shortcuts.gschema.xml.in:14
msgid "Keyboard shortcut definitions"
msgstr "ຄຳກຳນົດປຸ່ມລັດເທິງແປ້ນພິມ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:10
msgid "Smartcard removal action"
msgstr "ການກະທຳເມື່ອຖອດສະມາດກາດອອກ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:11
msgid ""
"Set this to one of “none”, “lock-screen”, or “force-logout”. The action will "
"get performed when the smartcard used for log in is removed."
msgstr "ຕັ້ງຄ່ານີ້ເປັນໜຶ່ງໃນ “none”, “lock-screen”, ຫຼື “force-logout”. ການກະທຳຈະຖືກປະຕິບັດເມື່ອສະມາດກາດທີ່ໃຊ້ໃນການເຂົ້າສູ່ລະບົບຖືກຖອດອອກ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:17
msgid "Whether the tablet’s orientation is locked, or rotated automatically."
msgstr "ບໍ່ວ່າຈະລັອກການວາງແນວຂອງແທັບເລັດ, ຫຼື ໝູນອັດຕະໂນມັດ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:25
msgid "Mouse button orientation"
msgstr "ການວາງແນວປຸ່ມເມົ້າ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:26
msgid "Swap left and right mouse buttons for left-handed mice."
msgstr "ສະຫຼັບປຸ່ມເມົ້າຊ້າຍ ແລະ ຂວາ ສຳລັບຜູ້ທີ່ຖະໜັດຊ້າຍ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:30
#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:107
msgid "Single Click"
msgstr "ຄລິກຄັ້ງດຽວ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:31
#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:108
msgid ""
"Acceleration multiplier for mouse motion. A value of -1 is the system "
"default."
msgstr "ຕົວຄູນການເລັ່ງຄວາມໄວສຳລັບການເຄື່ອນທີ່ຂອງເມົ້າ. ຄ່າ -1 ແມ່ນຄ່າເລີ່ມຕົ້ນຂອງລະບົບ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:35
#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:112
msgid "Motion Threshold"
msgstr "ຂອບເຂດການເຄື່ອນທີ່"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:36
#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:113
msgid ""
"Distance in pixels the pointer must move before accelerated mouse motion is "
"activated. A value of -1 is the system default."
msgstr "ໄລຍະຫ່າງເປັນພິກເຊວທີ່ຕົວຊີ້ຕ້ອງເຄື່ອນທີ່ກ່ອນທີ່ການເລັ່ງຄວາມໄວຂອງເມົ້າຈະຖືກເປີດໃຊ້. ຄ່າ -1 ແມ່ນຄ່າເລີ່ມຕົ້ນຂອງລະບົບ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:40
msgid "Middle button emulation"
msgstr "ການຈຳລອງປຸ່ມກາງ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:41
msgid ""
"Enables middle mouse button emulation through simultaneous left and right "
"button click."
msgstr "ເປີດໃຊ້ການຈຳລອງປຸ່ມກາງຂອງເມົ້າຜ່ານການຄລິກປຸ່ມຊ້າຍ ແລະ ຂວາພ້ອມກັນ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:45
msgid "Double click time"
msgstr "ເວລາຄລິກສອງຄັ້ງ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:46
msgid "Length of a double click in milliseconds."
msgstr "ຄວາມຍາວຂອງການຄລິກສອງຄັ້ງໃນຫົວໜ່ວຍມິນລິວິນາທີ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:50
msgid "Drag threshold"
msgstr "ຂອບເຂດການລາກ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:51
msgid "Distance before a drag is started."
msgstr "ໄລຍະຫ່າງກ່ອນທີ່ຈະເລີ່ມການລາກ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:60
msgid "Key Repeat Interval"
msgstr "ໄລຍະຫ່າງການກົດປຸ່ມຊ້ຳ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:61
msgid "Delay between repeats in milliseconds."
msgstr "ການໜ່ວງເວລາລະຫວ່າງການກົດຊ້ຳໃນຫົວໜ່ວຍມິນລິວິນາທີ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:65
msgid "Initial Key Repeat Delay"
msgstr "ການໜ່ວງເວລາເລີ່ມຕົ້ນຂອງການກົດປຸ່ມຊ້ຳ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:66
msgid "Initial key repeat delay in milliseconds."
msgstr "ການໜ່ວງເວລາເລີ່ມຕົ້ນຂອງການກົດປຸ່ມຊ້ຳໃນຫົວໜ່ວຍມິນລິວິນາທີ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:70
msgid "Remember NumLock state"
msgstr "ຈື່ຈຳສະຖານະ NumLock"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:71
msgid ""
"When set to true, GNOME will remember the state of the NumLock LED between "
"sessions."
msgstr "ເມື່ອຕັ້ງເປັນ true, GNOME ຈະຈື່ຈຳສະຖານະຂອງໄຟ LED NumLock ລະຫວ່າງການໃຊ້ງານ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:77
msgid "Disable touchpad while typing"
msgstr "ປິດໃຊ້ງານແຜ່ນສຳຜັດຂະນະພິມ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:78
msgid ""
"Set this to TRUE if you have problems with accidentally hitting the touchpad "
"while typing."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ຖ້າທ່ານມີບັນຫາກ່ຽວກັບການສຳຜັດແຜ່ນສຳຜັດໂດຍບັງເອີນຂະນະທີ່ກຳລັງພິມ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:82
msgid "Enable horizontal scrolling"
msgstr "ເປີດໃຊ້ການເລື່ອນແນວນອນ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:83
msgid ""
"Set this to TRUE to allow horizontal scrolling by the same method selected "
"with the scroll_method key."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອອະນຸຍາດໃຫ້ເລື່ອນແນວນອນດ້ວຍວິທີດຽວກັນກັບທີ່ເລືອກໄວ້ໃນຄີ scroll_method."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:87
msgid "Select the touchpad scroll method"
msgstr "ເລືອກວິທີການເລື່ອນຂອງແຜ່ນສຳຜັດ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:88
msgid ""
"Select the touchpad scroll method. Supported values are: “disabled”, “edge-"
"scrolling”, “two-finger-scrolling”."
msgstr "ເລືອກວິທີການເລື່ອນຂອງແຜ່ນສຳຜັດ. ຄ່າທີ່ຮອງຮັບແມ່ນ: “disabled”, “edge-scrolling”, “two-finger-scrolling”."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:92
msgid "Enable mouse clicks with touchpad"
msgstr "ເປີດໃຊ້ການຄລິກເມົ້າດ້ວຍແຜ່ນສຳຜັດ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:93
msgid ""
"Set this to TRUE to be able to send mouse clicks by tapping on the touchpad."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອໃຫ້ສາມາດສົ່ງການຄລິກເມົ້າໂດຍການແຕະເທິງແຜ່ນສຳຜັດ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:97
msgid "Enable touchpad"
msgstr "ເປີດໃຊ້ແຜ່ນສຳຜັດ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:98
msgid "Set this to TRUE to enable all touchpads."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອເປີດໃຊ້ງານແຜ່ນສຳຜັດທັງໝົດ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:102
msgid "Touchpad button orientation"
msgstr "ການວາງແນວປຸ່ມແຜ່ນສຳຜັດ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:103
msgid ""
"Swap left and right mouse buttons for left-handed mice with “left”, “right” "
"for right-handed, “mouse” to follow the mouse setting."
msgstr "ສະຫຼັບປຸ່ມເມົ້າຊ້າຍ ແລະ ຂວາສຳລັບຜູ້ທີ່ຖະໜັດຊ້າຍດ້ວຍ “left”, “right” ສຳລັບຜູ້ທີ່ຖະໜັດຂວາ, “mouse” ເພື່ອເຮັດຕາມການຕັ້ງຄ່າຂອງເມົ້າ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:117
msgid "Natural scrolling"
msgstr "ການເລື່ອນແບບທຳມະຊາດ"

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:118
msgid "Set this to TRUE to enable natural (reverse) scrolling for touchpads."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ TRUE ເພື່ອເປີດໃຊ້ການເລື່ອນແບບທຳມະຊາດ (ປີ້ນກັບ) ສຳລັບແຜ່ນສຳຜັດ."

#: data/org.gnome.settings-daemon.peripherals.gschema.xml.in:125
msgid "Mouse wheel emulation button. 0 to disable the feature."
msgstr "ປຸ່ມຈຳລອງລໍ້ເມົ້າ. 0 ເພື່ອປິດໃຊ້ງານຄຸນສົມບັດນີ້."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:10
msgid "Wacom stylus absolute mode"
msgstr "ໂໝດສຳບູນຂອງປາກກາ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:11
msgid "Enable this to set the tablet to absolute mode."
msgstr "ເປີດໃຊ້ອັນນີ້ເພື່ອຕັ້ງຄ່າແທັບເລັດເປັນໂໝດສຳບູນ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:15
msgid "Wacom tablet area"
msgstr "ພື້ນທີ່ແທັບເລັດ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:16
msgid "Set this to x1, y1 and x2, y2 of the area usable by the tools."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ x1, y1 ແລະ x2, y2 ຂອງພື້ນທີ່ທີ່ເຄື່ອງມືສາມາດໃຊ້ໄດ້."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:20
msgid "Wacom tablet aspect ratio"
msgstr "ອັດຕາສ່ວນຂອງແທັບເລັດ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:21
msgid ""
"Enable this to restrict the Wacom tablet area to match the aspect ratio of "
"the output."
msgstr "ເປີດໃຊ້ອັນນີ້ເພື່ອຈຳກັດພື້ນທີ່ແທັບເລັດ Wacom ໃຫ້ກົງກັບອັດຕາສ່ວນຂອງຜົນລັບ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:25
msgid "Wacom tablet rotation"
msgstr "ການໝູນຂອງແທັບເລັດ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:26
msgid ""
"Set this to “none”, “cw” for 90 degree clockwise, “half” for 180 degree, and "
"“ccw” for 90 degree counterclockwise."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ “none”, “cw” ສຳລັບການໝູນຕາມເຂັມໂມງ 90 ອົງສາ, “half” ສຳລັບ 180 ອົງສາ, ແລະ “ccw” ສຳລັບການໝູນທວນເຂັມໂມງ 90 ອົງສາ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:30
msgid "Wacom touch feature"
msgstr "ຄຸນສົມບັດການສຳຜັດຂອງ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:31
msgid "Enable this to move the cursor when the user touches the tablet."
msgstr "ເປີດໃຊ້ອັນນີ້ເພື່ອຍ້າຍຕົວຊີ້ເມື່ອຜູ້ໃຊ້ສຳຜັດແທັບເລັດ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:37
msgid "Wacom stylus pressure curve"
msgstr "ເສັ້ນໂຄ້ງຄວາມກົດດັນຂອງປາກກາ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:38
msgid ""
"Set this to x1, y1 and x2, y2 of the pressure curve applied to the stylus."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ x1, y1 ແລະ x2, y2 ຂອງເສັ້ນໂຄ້ງຄວາມກົດດັນທີ່ນຳໃຊ້ກັບປາກກາ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:42
msgid "Wacom stylus button mapping"
msgstr "ການຈັບຄູ່ປຸ່ມຂອງປາກກາ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:43
#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:60
msgid "Set this to the logical button mapping."
msgstr "ຕັ້ງຄ່ານີ້ເປັນການຈັບຄູ່ປຸ່ມຕາມເຫດຜົນ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:47
msgid "Wacom stylus pressure threshold"
msgstr "ຂອບເຂດຄວາມກົດດັນຂອງປາກກາ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:48
msgid ""
"Set this to the pressure value at which a stylus click event is generated."
msgstr "ຕັ້ງຄ່ານີ້ເປັນຄ່າຄວາມກົດດັນທີ່ເຫດການຄລິກປາກກາຈະຖືກສ້າງຂຶ້ນ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:54
msgid "Wacom eraser pressure curve"
msgstr "ເສັ້ນໂຄ້ງຄວາມກົດດັນຂອງຢາງລົບ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:55
msgid ""
"Set this to x1, y1 and x2, y2 of the pressure curve applied to the eraser."
msgstr "ຕັ້ງຄ່ານີ້ເປັນ x1, y1 ແລະ x2, y2 ຂອງເສັ້ນໂຄ້ງຄວາມກົດດັນທີ່ນຳໃຊ້ກັບຢາງລົບ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:59
msgid "Wacom eraser button mapping"
msgstr "ການຈັບຄູ່ປຸ່ມຂອງຢາງລົບ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:64
msgid "Wacom eraser pressure threshold"
msgstr "ຂອບເຂດຄວາມກົດດັນຂອງຢາງລົບ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:65
msgid ""
"Set this to the pressure value at which an eraser click event is generated."
msgstr "ຕັ້ງຄ່ານີ້ເປັນຄ່າຄວາມກົດດັນທີ່ເຫດການຄລິກຢາງລົບຈະຖືກສ້າງຂຶ້ນ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:71
msgid "Wacom button action type"
msgstr "ປະເພດການກະທຳຂອງປຸ່ມ Wacom"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:72
msgid "The type of action triggered by the button being pressed."
msgstr "ປະເພດຂອງການກະທຳທີ່ຖືກກະຕຸ້ນໂດຍການກົດປຸ່ມ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:76
msgid "Key combination for the custom action"
msgstr "ການປະສົມປຸ່ມສຳລັບການກະທຳທີ່ກຳນົດເອງ"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:77
msgid ""
"The keyboard shortcut generated when the button is pressed for custom "
"actions."
msgstr "ປຸ່ມລັດແປ້ນພິມທີ່ຖືກສ້າງຂຶ້ນເມື່ອກົດປຸ່ມສຳລັບການກະທຳທີ່ກຳນົດເອງ."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:81
msgid "Key combinations for a touchring or touchstrip custom action"
msgstr "ການປະສົມປຸ່ມສຳລັບການກະທຳທີ່ກຳນົດເອງຂອງ touchring ຫຼື touchstrip"

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:82
msgid ""
"The keyboard shortcuts generated when a touchring or touchstrip is used for "
"custom actions (up followed by down)."
msgstr "ປຸ່ມລັດແປ້ນພິມທີ່ຖືກສ້າງຂຶ້ນເມື່ອ touchring ຫຼື touchstrip ຖືກໃຊ້ສຳລັບການກະທຳທີ່ກຳນົດເອງ (ຂຶ້ນຕາມດ້ວຍລົງ)."

#. Translators: This is the OLED display on an Intuos4 tablet:
#. http://eu.shop.wacom.eu/images/articles/d9abd9f2d4d88aa0649cda97a8077e2b_8.jpg
#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:88
msgid "Button label for OLED display."
msgstr "ປ້າຍກຳກັບປຸ່ມສຳລັບຈໍສະແດງຜົນ OLED."

#: data/org.gnome.settings-daemon.peripherals.wacom.gschema.xml.in:89
msgid "Label will be rendered to OLED display belonging to the button"
msgstr "ປ້າຍກຳກັບຈະຖືກສະແດງເທິງຈໍ OLED ທີ່ຂຶ້ນກັບປຸ່ມນັ້ນ"

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:6
msgid "The duration a display profile is valid"
msgstr "ໄລຍະເວລາທີ່ໂປຣໄຟລ໌ຈໍສະແດງຜົນສາມາດໃຊ້ໄດ້"

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:7
msgid ""
"This is the number of days after which the display color profile is "
"considered invalid."
msgstr "ນີ້ແມ່ນຈຳນວນມື້ທີ່ໂປຣໄຟລ໌ສີຂອງຈໍສະແດງຜົນຈະຖືກຖືວ່າບໍ່ສາມາດໃຊ້ໄດ້."

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:11
msgid "The duration a printer profile is valid"
msgstr "ໄລຍະເວລາທີ່ໂປຣໄຟລ໌ເຄື່ອງພິມສາມາດໃຊ້ໄດ້"

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:12
msgid ""
"This is the number of days after which the printer color profile is "
"considered invalid."
msgstr "ນີ້ແມ່ນຈຳນວນມື້ທີ່ໂປຣໄຟລ໌ສີຂອງເຄື່ອງພິມຈະຖືກຖືວ່າບໍ່ສາມາດໃຊ້ໄດ້."

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:16
msgid "If the night light mode is enabled"
msgstr "ຖ້າໂໝດແສງກາງຄືນຖືກເປີດໃຊ້"

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:17
msgid ""
"Night light mode changes the color temperature of your display when the sun "
"has gone down or at preset times."
msgstr "ໂໝດແສງກາງຄືນຈະປ່ຽນອຸນຫະພູມສີຂອງຈໍສະແດງຜົນຂອງທ່ານເມື່ອຕາເວັນຕົກດິນ ຫຼື ໃນເວລາທີ່ຕັ້ງໄວ້ລ່ວງໜ້າ."

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:21
msgid "Temperature of the display when enabled"
msgstr "ອຸນຫະພູມຂອງຈໍສະແດງຜົນເມື່ອເປີດໃຊ້"

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:22
msgid ""
"This temperature in Kelvin is used to modify the screen tones when night "
"light mode is enabled. Higher values are bluer, lower redder."
msgstr "ອຸນຫະພູມນີ້ໃນຫົວໜ່ວຍເຄນວິນຖືກໃຊ້ເພື່ອປັບແຕ່ງສີສັນຂອງໜ້າຈໍເມື່ອໂໝດແສງກາງຄືນຖືກເປີດໃຊ້. ຄ່າທີ່ສູງກວ່າຈະເປັນສີຟ້າ, ຄ່າທີ່ຕ່ຳກວ່າຈະເປັນສີແດງ."

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:26
msgid "Use the sunrise and sunset"
msgstr "ໃຊ້ເວລາຕາເວັນຂຶ້ນ ແລະ ຕາເວັນຕົກ"

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:27
msgid ""
"Calculate the sunrise and sunset times automatically, from the current "
"location."
msgstr "ຄຳນວນເວລາຕາເວັນຂຶ້ນ ແລະ ຕາເວັນຕົກໂດຍອັດຕະໂນມັດ, ຈາກສະຖານທີ່ປັດຈຸບັນ."

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:31
msgid "The start time"
msgstr "ເວລາເລີ່ມຕົ້ນ"

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:32
msgid ""
"When “night-light-schedule-automatic” is disabled, use this start time in "
"hours from midnight."
msgstr "ເມື່ອ “night-light-schedule-automatic” ຖືກປິດໃຊ້ງານ, ໃຫ້ໃຊ້ເວລາເລີ່ມຕົ້ນນີ້ເປັນຊົ່ວໂມງນັບຈາກທ່ຽງຄືນ."

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:36
msgid "The end time"
msgstr "ເວລາສິ້ນສຸດ"

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:37
msgid ""
"When “night-light-schedule-automatic” is disabled, use this end time in "
"hours from midnight."
msgstr "ເມື່ອ “night-light-schedule-automatic” ຖືກປິດໃຊ້ງານ, ໃຫ້ໃຊ້ເວລາສິ້ນສຸດນີ້ເປັນຊົ່ວໂມງນັບຈາກທ່ຽງຄືນ."

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:41
msgid "The last detected position"
msgstr "ຕຳແໜ່ງທີ່ກວດພົບຫຼ້າສຸດ"

#: data/org.gnome.settings-daemon.plugins.color.gschema.xml.in:42
msgid ""
"When location services are available this represents the last detected "
"location. The default value is an invalid value to ensure it is always "
"updated at startup."
msgstr "ເມື່ອບໍລິການສະຖານທີ່ມີໃຫ້ໃຊ້, ອັນນີ້ສະແດງເຖິງຕຳແໜ່ງທີ່ກວດພົບຫຼ້າສຸດ. ຄ່າເລີ່ມຕົ້ນແມ່ນຄ່າທີ່ບໍ່ຖືກຕ້ອງ ເພື່ອໃຫ້ແນ່ໃຈວ່າມັນຈະຖືກອັບເດດສະເໝີເມື່ອເລີ່ມຕົ້ນລະບົບ."

#: data/org.gnome.settings-daemon.plugins.gschema.xml.in:6
msgid "List of plugins that are allowed to be loaded"
msgstr "ລາຍຊື່ປລັກອິນທີ່ອະນຸຍາດໃຫ້ໂຫຼດ"

#: data/org.gnome.settings-daemon.plugins.gschema.xml.in:7
msgid ""
"A list of strings representing the plugins that are allowed to be loaded "
"(default: “all”). This is only evaluated on startup."
msgstr "ລາຍຊື່ຂໍ້ຄວາມທີ່ສະແດງເຖິງປລັກອິນທີ່ອະນຸຍາດໃຫ້ໂຫຼດ (ຄ່າເລີ່ມຕົ້ນ: “all”). ອັນນີ້ຈະຖືກປະເມີນເມື່ອເລີ່ມຕົ້ນລະບົບເທົ່ານັ້ນ."

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:6
msgid "Mount paths to ignore"
msgstr "ເສັ້ນທາງ mount ທີ່ຕ້ອງບໍ່ສົນໃຈ"

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:7
msgid "Specify a list of mount paths to ignore when they run low on space."
msgstr "ລະບຸລາຍຊື່ເສັ້ນທາງ mount ທີ່ຕ້ອງບໍ່ສົນໃຈ ເມື່ອພວກມັນມີພື້ນທີ່ເຫຼືອໜ້ອຍ."

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:12
msgid "Free percentage notify threshold"
msgstr "ຂອບເຂດການແຈ້ງເຕືອນເປີເຊັນພື້ນທີ່ວ່າງ"

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:13
msgid ""
"Percentage free space threshold for initial warning of low disk space. If "
"the percentage free space drops below this, a warning will be shown."
msgstr "ຂອບເຂດເປີເຊັນຂອງພື້ນທີ່ວ່າງສຳລັບການເຕືອນເບື້ອງຕົ້ນກ່ຽວກັບພື້ນທີ່ດິສເຫຼືອໜ້ອຍ. ຖ້າເປີເຊັນຂອງພື້ນທີ່ວ່າງຫຼຸດລົງຕ່ຳກວ່າຄ່ານີ້, ການແຈ້ງເຕືອນຈະປະກົດຂຶ້ນ."

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:18
msgid "Subsequent free space percentage notify threshold"
msgstr "ຂອບເຂດການແຈ້ງເຕືອນເປີເຊັນພື້ນທີ່ວ່າງຄັ້ງຕໍ່ໄປ"

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:19
msgid ""
"Specify the percentage that the free disk space should reduce by before "
"issuing a subsequent warning."
msgstr "ລະບຸເປີເຊັນທີ່ພື້ນທີ່ດິສວ່າງຄວນຫຼຸດລົງກ່ອນທີ່ຈະອອກຄຳເຕືອນຄັ້ງຕໍ່ໄປ."

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:23
msgid "Free space notify threshold"
msgstr "ຂອບເຂດການແຈ້ງເຕືອນພື້ນທີ່ວ່າງ"

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:24
msgid ""
"Specify an amount in GB. If the amount of free space is more than this, no "
"warning will be shown."
msgstr "ລະບຸຈຳນວນເປັນ GB. ຖ້າຈຳນວນພື້ນທີ່ວ່າງມີຫຼາຍກວ່ານີ້, ຈະບໍ່ມີການແຈ້ງເຕືອນສະແດງ."

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:28
msgid "Minimum notify period for repeated warnings"
msgstr "ໄລຍະເວລາແຈ້ງເຕືອນຂັ້ນຕ່ຳສຳລັບການເຕືອນຊ້ຳ"

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:29
msgid ""
"Specify a time in minutes. Subsequent warnings for a volume will not appear "
"more often than this period."
msgstr "ລະບຸເວລາເປັນນາທີ. ການເຕືອນຄັ້ງຕໍ່ໄປສຳລັບ volume ຈະບໍ່ປາກົດຂຶ້ນເລື້ອຍກວ່າໄລຍະເວລານີ້."

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:33
msgid "Whether donation reminders are enabled"
msgstr "ເປີດໃຊ້ການແຈ້ງເຕືອນການບໍລິຈາກຫຼືບໍ່"

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:34
msgid "Enables or disables the low-frequency donation reminder notification."
msgstr "ເປີດ ຫຼື ປິດການແຈ້ງເຕືອນການບໍລິຈາກທີ່ມີຄວາມຖີ່ຕ່ຳ."

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:38
msgid "Last time the donation reminder was shown"
msgstr "ເວລາຫຼ້າສຸດທີ່ການແຈ້ງເຕືອນການບໍລິຈາກໄດ້ສະແດງ"

#: data/org.gnome.settings-daemon.plugins.housekeeping.gschema.xml.in:39
msgid "Timestamp for the last time a donation reminder was shown."
msgstr "ເວລາທີ່ການແຈ້ງເຕືອນການບໍລິຈາກໄດ້ສະແດງຄັ້ງຫຼ້າສຸດ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:6
#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:154
#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:440
msgid "Launch calculator"
msgstr "ເປີດເຄື່ອງຄິດເລກ"

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:7
#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:155
msgid "Binding to launch the calculator."
msgstr "ການຈັບຄູ່ເພື່ອເປີດເຄື່ອງຄິດເລກ."

#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:11
#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:159
#: data/org.gnome.settings-daemon.plugins.media-keys.gschema.xml.in:445
msgid "Launch settings"
